# ---- ADX DUBAI backend env ----
MONGO_URL=""
DB_NAME="adxsite"

# Comma-separated list of allowed CORS origins.
# Example: CORS_ORIGINS="https://adx.example.com,https://www.adx.example.com"
CORS_ORIGINS=""

# Frontend URL (also used for Telegram webhook registration if BACKEND_URL is not set)
FRONTEND_URL=""

# Public backend URL (used for Telegram webhook registration). If unset, FRONTEND_URL is used.
BACKEND_URL=""

# JWT signing secret (long random string)
JWT_SECRET=""

# Seeded admin account credentials
ADMIN_EMAIL=""
ADMIN_PASSWORD=""

# Live chat (e.g., Tawk/Crisp) URL — optional
LIVE_CHAT_URL=""

# Telegram bot for deposit/withdraw notifications
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_CHAT_ID=""
# Optional shared secret. If set, /api/telegram/webhook will reject requests
# whose X-Telegram-Bot-Api-Secret-Token header does not match.
TELEGRAM_WEBHOOK_SECRET=""

# On-chain deposit addresses
USDT_WALLET=""
BTC_WALLET=""
ETH_WALLET=""
TRX_WALLET=""
BNB_WALLET=""
